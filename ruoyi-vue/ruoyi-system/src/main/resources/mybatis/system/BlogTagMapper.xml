<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BlogTagMapper">
    <resultMap type="com.ruoyi.system.domain.BlogTag" id="BlogTagResult">
        <result property="tagId" column="tag_id"/>
        <result property="tagName" column="tag_name"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectBlogTagVo">
        select tag_id, tag_name, create_by, create_time, update_by, update_time, remark from blog_tag
    </sql>

    <select id="selectBlogTagList" parameterType="com.ruoyi.system.domain.BlogTag" resultMap="BlogTagResult">
        <include refid="selectBlogTagVo"/>
        <where>
            <if test="tagName != null and tagName != ''">and tag_name like concat('%', #{tagName}, '%')</if>
            <if test="remark != null and remark != ''">and remark like concat('%', #{remark}, '%')</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectBlogTagById" parameterType="Long" resultMap="BlogTagResult">
        <include refid="selectBlogTagVo"/>
        where tag_id = #{tagId}
    </select>

    <select id="selectAllTagList" resultMap="BlogTagResult">
        select tag_id, tag_name from blog_tag order by create_time desc
    </select>

    <select id="checkTagNameUnique" parameterType="String" resultMap="BlogTagResult">
        <include refid="selectBlogTagVo"/>
        where tag_name = #{tagName}
    </select>

    <insert id="insertBlogTag" parameterType="com.ruoyi.system.domain.BlogTag" useGeneratedKeys="true" keyProperty="tagId">
        insert into blog_tag
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="tagName != null and tagName != ''">tag_name,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null and remark != ''">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="tagName != null and tagName != ''">#{tagName},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
        </trim>
    </insert>

    <update id="updateBlogTag" parameterType="com.ruoyi.system.domain.BlogTag">
        update blog_tag
        <set>
            <if test="tagName != null and tagName != ''">tag_name = #{tagName},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null and remark != ''">remark = #{remark},</if>
        </set>
        where tag_id = #{tagId}
    </update>

    <delete id="deleteBlogTagById" parameterType="Long">
        delete from blog_tag where tag_id = #{tagId}
    </delete>

    <delete id="deleteBlogTagByIds" parameterType="Long[]">
        delete from blog_tag where tag_id in
        <foreach item="tagId" collection="array" open="(" separator="," close=")">
            #{tagId}
        </foreach>
    </delete>
</mapper>