<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BlogArticleMapper">
    
    <resultMap type="BlogArticle" id="BlogArticleResult">
        <result property="id"    column="id"    />
        <result property="title"    column="title"    />
        <result property="summary"    column="summary"    />
        <result property="content"    column="content"    />
        <result property="coverUrl"    column="cover_url"    />
        <result property="categoryId"    column="category_id"    />
        <result property="authorId"    column="author_id"    />
        <result property="isTop"    column="is_top"    />
        <result property="isRecommend"    column="is_recommend"    />
        <result property="status"    column="status"    />
        <result property="viewCount"    column="view_count"    />
        <result property="likeCount"    column="like_count"    />
        <result property="commentCount"    column="comment_count"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <resultMap type="BlogArticle" id="SimpleBlogArticleResult">
        <result property="id"    column="id"    />
        <result property="title"    column="title"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectBlogArticleVo">
        select ba.id, ba.title, ba.summary, ba.content, ba.cover_url, ba.category_id, ba.author_id, 
               ba.is_top, ba.is_recommend, ba.status, ba.view_count, 
               ba.like_count, ba.comment_count, ba.create_time, ba.update_time, ba.del_flag,
               bc.name as category_name,
               GROUP_CONCAT(DISTINCT bt.id) as tag_ids,
               GROUP_CONCAT(DISTINCT bt.name) as tag_names
        from blog_article ba
        left join blog_category bc on ba.category_id = bc.id and bc.del_flag = 0
        left join blog_article_tag bat on ba.id = bat.article_id
        left join blog_tag bt on bat.tag_id = bt.id and bt.del_flag = 0
        group by ba.id, ba.title, ba.summary, ba.content, ba.cover_url, ba.category_id, ba.author_id, 
                 ba.is_top, ba.is_recommend, ba.status, ba.view_count, ba.like_count, 
                 ba.comment_count, ba.create_time, ba.update_time, ba.del_flag, bc.name
    </sql>

    <select id="selectBlogArticleList" parameterType="BlogArticle" resultMap="BlogArticleResult">
        <include refid="selectBlogArticleVo"/>
        <where>  
            <if test="title != null  and title != ''"> and ba.title = #{title}</if>
            <if test="summary != null  and summary != ''"> and ba.summary = #{summary}</if>
            <if test="content != null  and content != ''"> and ba.content = #{content}</if>
            <if test="coverUrl != null  and coverUrl != ''"> and ba.cover_url = #{coverUrl}</if>
            <if test="categoryId != null "> and ba.category_id = #{categoryId}</if>
            <if test="authorId != null "> and ba.author_id = #{authorId}</if>
            <if test="isTop != null "> and ba.is_top = #{isTop}</if>
            <if test="isRecommend != null "> and ba.is_recommend = #{isRecommend}</if>
            <if test="status != null "> and ba.status = #{status}</if>
            <if test="viewCount != null "> and ba.view_count = #{viewCount}</if>
            <if test="likeCount != null "> and ba.like_count = #{likeCount}</if>
            <if test="commentCount != null "> and ba.comment_count = #{commentCount}</if>
        </where>
        order by ba.create_time desc
    </select>
    
    <select id="selectBlogArticleById" parameterType="Long" resultMap="BlogArticleResult">
        <include refid="selectBlogArticleVo"/>
        where id = #{id}
    </select>

    <select id="selectBlogArticleByTitle" parameterType="String" resultMap="BlogArticleResult">
        select ba.id, ba.title, ba.summary, ba.content, ba.cover_url, ba.category_id, ba.author_id, 
               ba.is_top, ba.is_recommend, ba.status, ba.view_count, 
               ba.like_count, ba.comment_count, ba.create_time, ba.update_time, ba.del_flag 
        from blog_article ba
        where ba.title = #{title} limit 1
    </select>

    <insert id="insertBlogArticle" parameterType="BlogArticle" useGeneratedKeys="true" keyProperty="id">
        insert into blog_article
        (title, summary, content, cover_url, category_id, author_id, is_top, is_recommend, status, view_count, like_count, comment_count, create_time, update_time, del_flag)
        values
        (#{title}, #{summary}, #{content}, #{coverUrl}, #{categoryId}, #{authorId}, #{isTop}, #{isRecommend}, #{status}, #{viewCount}, #{likeCount}, #{commentCount}, #{createTime}, #{updateTime}, 
        <choose>
            <when test="delFlag != null">#{delFlag}</when>
            <otherwise>0</otherwise>
        </choose>)
    </insert>

    <update id="updateBlogArticle" parameterType="BlogArticle">
        update blog_article
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="summary != null">summary = #{summary},</if>
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="coverUrl != null">cover_url = #{coverUrl},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="authorId != null">author_id = #{authorId},</if>
            <if test="isTop != null">is_top = #{isTop},</if>
            <if test="isRecommend != null">is_recommend = #{isRecommend},</if>
            <if test="status != null">status = #{status},</if>
            <if test="viewCount != null">view_count = #{viewCount},</if>
            <if test="likeCount != null">like_count = #{likeCount},</if>
            <if test="commentCount != null">comment_count = #{commentCount},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where id = #{id}
    </update>

    <update id="addViewCount" parameterType="Long">
        update blog_article set view_count = view_count + 1 where id = #{id}
    </update>

    <select id="selectArticlesByTagId" parameterType="Long" resultMap="BlogArticleResult">
        <include refid="selectBlogArticleVo"/>
        inner join blog_article_tag bat on ba.id = bat.article_id
        where bat.tag_id = #{tagId} and ba.status = 1 and ba.del_flag = 0
        order by ba.create_time desc
    </select>

    <select id="searchArticles" resultMap="BlogArticleResult">
        <include refid="selectBlogArticleVo"/>
        <where>
            ba.status = 1 and ba.del_flag = 0
            <if test="keyword != null and keyword != ''">
                and (ba.title like concat('%', #{keyword}, '%') or ba.content like concat('%', #{keyword}, '%'))
            </if>
            <if test="blogArticle.categoryId != null">
                and ba.category_id = #{blogArticle.categoryId}
            </if>
            <if test="blogArticle.isTop != null">
                and ba.is_top = #{blogArticle.isTop}
            </if>
            <if test="blogArticle.isRecommend != null">
                and ba.is_recommend = #{blogArticle.isRecommend}
            </if>
        </where>
        order by ba.create_time desc
    </select>

    <select id="getArticleArchive" resultType="map">
        SELECT 
            DATE_FORMAT(create_time, '%Y-%m') as archive_date,
            COUNT(*) as article_count
        FROM blog_article 
        WHERE status = 1 AND del_flag = 0
        GROUP BY DATE_FORMAT(create_time, '%Y-%m')
        ORDER BY archive_date DESC
    </select>

    <select id="getPrevArticle" resultMap="SimpleBlogArticleResult" parameterType="Long">
        SELECT id, title, del_flag FROM blog_article 
        WHERE id &lt; #{id} AND status = 1 AND del_flag = 0 
        ORDER BY id DESC LIMIT 1
    </select>

    <select id="getNextArticle" resultMap="SimpleBlogArticleResult" parameterType="Long">
        SELECT id, title, del_flag FROM blog_article 
        WHERE id &gt; #{id} AND status = 1 AND del_flag = 0 
        ORDER BY id ASC LIMIT 1
    </select>

    <delete id="deleteBlogArticleById" parameterType="Long">
        delete from blog_article where id = #{id}
    </delete>

    <delete id="deleteBlogArticleByIds" parameterType="String">
        delete from blog_article where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="countByCategoryIds" resultType="int">
        select count(1) from blog_article where del_flag = 0 and category_id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
</mapper>