<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.ArticleTagMapper">
    
    <resultMap type="ArticleTag" id="ArticleTagResult">
        <result property="articleId"    column="article_id"    />
        <result property="tagId"    column="tag_id"    />
    </resultMap>

    <sql id="selectArticleTagVo">
        select article_id, tag_id from article_tag
    </sql>

    <select id="selectArticleTagList" parameterType="ArticleTag" resultMap="ArticleTagResult">
        <include refid="selectArticleTagVo"/>
        <where>  
        </where>
    </select>
    
    <select id="selectArticleTagByArticleId" parameterType="Long" resultMap="ArticleTagResult">
        <include refid="selectArticleTagVo"/>
        where article_id = #{articleId}
    </select>

    <insert id="insertArticleTag" parameterType="ArticleTag">
        insert into article_tag
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="articleId != null">article_id,</if>
            <if test="tagId != null">tag_id,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="articleId != null">#{articleId},</if>
            <if test="tagId != null">#{tagId},</if>
         </trim>
    </insert>

    <update id="updateArticleTag" parameterType="ArticleTag">
        update article_tag
        <trim prefix="SET" suffixOverrides=",">
            <if test="tagId != null">tag_id = #{tagId},</if>
        </trim>
        where article_id = #{articleId}
    </update>

    <delete id="deleteArticleTagByArticleId" parameterType="Long">
        delete from article_tag where article_id = #{articleId}
    </delete>

    <delete id="deleteArticleTagByArticleIds" parameterType="String">
        delete from article_tag where article_id in 
        <foreach item="articleId" collection="array" open="(" separator="," close=")">
            #{articleId}
        </foreach>
    </delete>
</mapper>