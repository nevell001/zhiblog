# NewBlog 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 警告: .env 文件包含敏感信息，不要提交到版本控制系统

# ===========================================
# 系统配置
# ===========================================
# 时区设置
TZ=Asia/Shanghai
LANG=C.UTF-8
LC_ALL=C.UTF-8

# ===========================================
# 数据库配置
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=newblog
DB_USERNAME=root
DB_PASSWORD=your_strong_password_here

# ===========================================
# Redis配置
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ===========================================
# JWT令牌配置
# ===========================================
# JWT密钥（必须修改为随机字符串，至少64位）
R_TOKEN_SECRET=your_very_long_and_secure_random_token_secret_key_at_least_64_characters_long_please_change_this

# Token过期时间（分钟，默认1440分钟 = 24小时）
TOKEN_EXPIRE_TIME=1440

# ===========================================
# Druid监控配置
# ===========================================
# Druid监控用户名
DRUID_USERNAME=ruoyi
# Druid监控密码（必须设置强密码）
DRUID_PASSWORD=your_strong_druid_password_here

# ===========================================
# Grafana配置
# ===========================================
# Grafana管理员用户名
GF_SECURITY_ADMIN_USER=admin
# Grafana管理员密码
GF_SECURITY_ADMIN_PASSWORD=your_strong_grafana_password_here

# ===========================================
# 应用配置
# ===========================================
# 应用端口
SERVER_PORT=8080

# 环境配置（dev/prod）
SPRING_PROFILES_ACTIVE=dev

# 验证码开关
CAPTCHA_ENABLED=false

# ===========================================
# 文件上传配置
# ===========================================
# 上传文件大小限制（默认10MB）
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=10MB

# ===========================================
# 日志配置
# ===========================================
# 日志级别（TRACE, DEBUG, INFO, WARN, ERROR）
LOGGING_LEVEL_ROOT=INFO

# ===========================================
# 安全配置
# ===========================================
# 防盗链开关
REFERER_ENABLED=false

# 允许的域名列表（逗号分隔）
REFERER_ALLOWED_DOMAINS=localhost,127.0.0.1

# ===========================================
# CORS配置
# ===========================================
# 允许的跨域来源
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===========================================
# 邮件配置（可选）
# ===========================================
# 邮件服务器主机
MAIL_HOST=smtp.example.com
# 邮件服务器端口
MAIL_PORT=465
# 邮件用户名
MAIL_USERNAME=your_email@example.com
# 邮件密码或授权码
MAIL_PASSWORD=your_email_password
# 是否使用SSL
MAIL_SSL=true

# ===========================================
# OSS对象存储配置（可选）
# ===========================================
# OSS提供商（aliyun, qcloud, minio等）
OSS_PROVIDER=
# OSS访问密钥ID
OSS_ACCESS_KEY_ID=
# OSS访问密钥Secret
OSS_ACCESS_KEY_SECRET=
# OSS桶名称
OSS_BUCKET_NAME=
# OSS端点
OSS_ENDPOINT=

# ===========================================
# Docker环境标识
# ===========================================
# 设置为true表示在Docker环境中运行
DOCKER=false

# ===========================================
# 监控配置
# ===========================================
# Prometheus端口
PROMETHEUS_PORT=9090
# Grafana端口
GRAFANA_PORT=3001

# ===========================================
# 健康检查配置
# ===========================================
# 健康检查间隔（秒）
HEALTH_CHECK_INTERVAL=30

# ===========================================
# 性能优化配置
# ===========================================
# 数据库连接池最大连接数
DB_POOL_MAX_ACTIVE=50
# 数据库连接池初始连接数
DB_POOL_INITIAL_SIZE=5
# 数据库连接池最小空闲连接数
DB_POOL_MIN_IDLE=5

# ===========================================
# 缓存配置
# ===========================================
# 缓存过期时间（秒，默认7200秒 = 2小时）
CACHE_EXPIRE_TIME=7200

# ===========================================
# 安全提示
# ===========================================
# 1. 生产环境必须修改所有默认密码
# 2. 使用强密码（至少16位，包含大小写字母、数字和特殊字符）
# 3. 定期轮换密钥和密码
# 4. 不要将.env文件提交到版本控制系统
# 5. 在生产环境中使用HTTPS
# 6. 启用防火墙和网络隔离
# 7. 定期备份配置和数据
