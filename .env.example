# ZhiBlog 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 警告: .env 文件包含敏感信息，不要提交到版本控制系统

# ===========================================
# 🔴 安全警告（必读）🔴
# ===========================================
# 1. 生产环境必须设置所有密码和密钥，应用启动时会自动验证
# 2. 禁止使用默认值或空密码，否则应用将无法启动（生产环境）
# 3. 强密码生成命令: openssl rand -base64 32
# 4. JWT密钥生成命令: openssl rand -base64 64
# 5. 开发环境可以通过设置 SECURITY_VALIDATION_ENABLED=false 跳过验证
# 6. 生产环境建议的密码长度: 至少32位随机字符
# ===========================================

# ===========================================
# 系统配置
# ===========================================
# 时区设置
TZ=Asia/Shanghai
LANG=C.UTF-8
LC_ALL=C.UTF-8

# ===========================================
# 数据库配置
# ===========================================
# 数据库主机地址
DB_HOST=localhost
# 数据库端口
DB_PORT=3306
# 数据库名称
DB_NAME=zhiblog
# 数据库应用用户名（生产环境不要使用root）
DB_USERNAME=zhiblog_app
# 🔴 数据库应用密码（生产环境必填）
# 生成命令: openssl rand -base64 32
DB_PASSWORD=your_strong_password_here
# 🔴 MySQL root密码（仅用于容器初始化和健康检查，应用不使用）
# 生成命令: openssl rand -base64 32
DB_ROOT_PASSWORD=your_strong_root_password_here

# ===========================================
# Redis配置
# ===========================================
# Redis主机地址
REDIS_HOST=localhost
# Redis端口
REDIS_PORT=6379
# 🔴 Redis密码（生产环境必填）
# 生成命令: openssl rand -base64 32
# 留空表示无密码（仅开发环境）
REDIS_PASSWORD=
# Redis数据库索引
REDIS_DATABASE=0

# ===========================================
# JWT令牌配置
# ===========================================
# 🔴 JWT密钥（生产环境必填，至少64位）
# 生成命令: openssl rand -base64 64
# 警告：此密钥用于签名所有JWT令牌，泄露将导致严重安全问题
R_TOKEN_SECRET=your_very_long_and_secure_random_token_secret_key_at_least_64_characters_long_please_change_this

# Token过期时间（分钟，默认1440分钟 = 24小时）
TOKEN_EXPIRE_TIME=1440

# ===========================================
# Druid监控配置
# ===========================================
# Druid监控用户名
DRUID_USERNAME=nevell
# 🔴 Druid监控密码（生产环境必填）
# 生成命令: openssl rand -base64 32
# 警告：Druid监控包含数据库连接池信息，需要密码保护
DRUID_PASSWORD=your_strong_druid_password_here

# ===========================================
# Grafana配置
# ===========================================
# Grafana管理员用户名
GF_SECURITY_ADMIN_USER=admin
# Grafana管理员密码
GF_SECURITY_ADMIN_PASSWORD=your_strong_grafana_password_here

# ===========================================
# 应用配置
# ===========================================
# 应用端口
SERVER_PORT=8080

# 环境配置（dev/prod）
SPRING_PROFILES_ACTIVE=dev

# 验证码开关（建议开发和生产环境保持一致，都开启验证码）
CAPTCHA_ENABLED=true

# ===========================================
# 文件上传配置
# ===========================================
# 上传文件大小限制（默认10MB）
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=10MB

# ===========================================
# 日志配置
# ===========================================
# 日志级别（TRACE, DEBUG, INFO, WARN, ERROR）
LOGGING_LEVEL_ROOT=INFO

# ===========================================
# 安全配置
# ===========================================
# 防盗链开关
REFERER_ENABLED=false

# 允许的域名列表（逗号分隔）
REFERER_ALLOWED_DOMAINS=localhost,127.0.0.1

# ===========================================
# CORS配置
# ===========================================
# 允许的跨域来源
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===========================================
# 邮件配置（可选）
# ===========================================
# 邮件服务器主机
MAIL_HOST=smtp.example.com
# 邮件服务器端口
MAIL_PORT=465
# 邮件用户名
MAIL_USERNAME=your_email@example.com
# 邮件密码或授权码
MAIL_PASSWORD=your_email_password
# 是否使用SSL
MAIL_SSL=true

# ===========================================
# OSS对象存储配置（可选）
# ===========================================
# OSS提供商（aliyun, qcloud, minio等）
OSS_PROVIDER=
# OSS访问密钥ID
OSS_ACCESS_KEY_ID=
# OSS访问密钥Secret
OSS_ACCESS_KEY_SECRET=
# OSS桶名称
OSS_BUCKET_NAME=
# OSS端点
OSS_ENDPOINT=

# ===========================================
# Docker环境标识
# ===========================================
# 设置为true表示在Docker环境中运行
DOCKER=false

# ===========================================
# 监控配置
# ===========================================
# Prometheus端口
PROMETHEUS_PORT=9090
# Grafana端口
GRAFANA_PORT=3001

# ===========================================
# 健康检查配置
# ===========================================
# 健康检查间隔（秒）
HEALTH_CHECK_INTERVAL=30

# ===========================================
# 性能优化配置
# ===========================================
# 数据库连接池最大连接数
DB_POOL_MAX_ACTIVE=50
# 数据库连接池初始连接数
DB_POOL_INITIAL_SIZE=5
# 数据库连接池最小空闲连接数
DB_POOL_MIN_IDLE=5

# ===========================================
# 缓存配置
# ===========================================
# 缓存过期时间（秒，默认7200秒 = 2小时）
CACHE_EXPIRE_TIME=7200

# ===========================================
# 安全提示
# ===========================================
# 1. 生产环境必须修改所有默认密码
# 2. 使用强密码（至少32位，包含大小写字母、数字和特殊字符）
# 3. 定期轮换密钥和密码
# 4. 不要将.env文件提交到版本控制系统
# 5. 在生产环境中使用HTTPS
# 6. 启用防火墙和网络隔离
# 7. 定期备份配置和数据
# 8. 应用启动时自动验证安全配置（生产环境强制执行）

# ===========================================
# 安全配置验证
# ===========================================
# 是否启用安全配置验证（默认启用）
# 生产环境强制启用，无法禁用
# 开发环境可以设置为 false 来跳过验证
SECURITY_VALIDATION_ENABLED=true
