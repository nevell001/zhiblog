#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# 提交信息规范检查
commit_regex='^(feat|fix|docs|style|refactor|perf|test|chore|build|ci)(\(.+\))?: .{1,50}'

if ! grep -qE "$commit_regex" "$1"; then
  echo ""
  echo "❌ 提交信息格式不符合规范！"
  echo ""
  echo "正确的格式："
  echo "  type(scope): subject"
  echo ""
  echo "类型（type）:"
  echo "  feat     - 新功能"
  echo "  fix      - 修复bug"
  echo "  docs     - 文档更新"
  echo "  style    - 代码格式"
  echo "  refactor - 重构"
  echo "  perf     - 性能优化"
  echo "  test     - 测试相关"
  echo "  chore    - 构建/工具变更"
  echo "  build    - 构建系统"
  echo "  ci       - CI配置"
  echo ""
  echo "示例："
  echo "  feat(blog): 添加文章分类功能"
  echo "  fix(auth): 修复登录超时问题"
  echo "  docs: 更新README文档"
  echo ""
  exit 1
fi

echo "✅ 提交信息格式检查通过"
