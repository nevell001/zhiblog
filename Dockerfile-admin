FROM maven:3.8.8-eclipse-temurin-17 AS builder

WORKDIR /app
COPY . .

# 编译项目，跳过测试编译
RUN mvn clean package -Dmaven.test.skip=true

FROM eclipse-temurin:17-jre

WORKDIR /app

# 安装必要的工具（用于健康检查）
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# 复制编译好的JAR包
COPY --from=builder /app/ruoyi-admin/target/ruoyi-admin.jar /app/ruoyi-admin.jar

# 创建上传目录
RUN mkdir -p /app/uploadPath && chmod 755 /app/uploadPath

# 设置时区
ENV TZ=Asia/Shanghai

# 启动命令 - 使用 curl 等待 MySQL 就绪
CMD sh -c "ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone && for i in {1..60}; do curl -f mysql:3306 2>/dev/null && echo 'MySQL is ready' && break || echo 'waiting mysql...' && sleep 2; done && java -jar /app/ruoyi-admin.jar"
