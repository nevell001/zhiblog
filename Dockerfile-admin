# 构建阶段 - 使用支持 ARM64 的基础镜像
FROM maven:3.9.9-eclipse-temurin-17 AS builder

WORKDIR /app

# 复制 pom.xml 并下载依赖（利用 Docker 缓存）
COPY pom.xml .
COPY ruoyi-common/pom.xml ruoyi-common/
COPY ruoyi-framework/pom.xml ruoyi-framework/
COPY ruoyi-system/pom.xml ruoyi-system/
COPY ruoyi-quartz/pom.xml ruoyi-quartz/
COPY ruoyi-generator/pom.xml ruoyi-generator/
COPY ruoyi-admin/pom.xml ruoyi-admin/

# 下载依赖到本地仓库
RUN mvn dependency:go-offline -B

# 复制源代码
COPY . .

# 编译项目并清理 Maven 缓存
RUN mvn clean package -Dmaven.test.skip=true -Dmaven.compiler.parameters=true -Dmaven.resources.filtering=true \
    && rm -rf /root/.m2/repository

# 运行阶段 - 使用支持 ARM64 的 JRE 镜像
FROM eclipse-temurin:17-jre

WORKDIR /app

# 设置时区并安装健康检查所需工具
ENV TZ=Asia/Shanghai
RUN apt-get update && apt-get install -y --no-install-recommends curl tzdata \
    && ln -snf /usr/share/zoneinfo/$TZ /etc/localtime \
    && echo $TZ > /etc/timezone \
    && rm -rf /var/lib/apt/lists/*

# 复制编译好的 JAR 包
COPY --from=builder /app/ruoyi-admin/target/ruoyi-admin.jar /app/ruoyi-admin.jar

# 创建上传目录
RUN mkdir -p /app/uploadPath \
    && chmod 755 /app/uploadPath

# 启动命令
CMD ["java", "-jar", "/app/ruoyi-admin.jar"]
